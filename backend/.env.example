APP_NAME=meridian-support-agent
DEBUG=true

SECRET_KEY=change-me-use-long-random-string
SECURE_COOKIES=false
ACCESS_TOKEN_EXPIRE_MINUTES=10080

HOST=http://localhost:8000
# Include :8000 when serving the static Next export from the same FastAPI origin
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL or CockroachDB (postgresql+asyncpg://…). Put CA cert under backend/.postgresql/ (e.g. root.crt from Cockroach Cloud).
# Cockroach Cloud (TLS): omit sslmode/sslrootcert from DATABASE_URL; set:
#   POSTGRES_SSL_MODE=verify-full
#   POSTGRES_SSL_ROOT_CERT=.postgresql/root.crt
# Local insecure node only:
#   DATABASE_SSL_DISABLE=true
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meridian_support
POSTGRES_SSL_MODE=
POSTGRES_SSL_ROOT_CERT=

GOOGLE_CLIENT_ID=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

MAX_REACT_ITERATIONS=8

# Optional: Model Context Protocol (Streamable HTTP) for ReAct tools.
# MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
# MCP_SERVER_ID=meridian_orders
# MCP_HTTP_TIMEOUT_SECONDS=120
