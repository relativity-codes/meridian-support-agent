# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console → APIs & Services → Credentials).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# For `next dev` on :3000 while API runs on :8000. Leave empty when UI is served from FastAPI static/ (same origin).
# If you set a URL, match the browser host (use 127.0.0.1 in the URL if you open http://127.0.0.1:8000, not localhost).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
